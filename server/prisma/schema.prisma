generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  DIRECTOR
  EQUIPO
  SOLICITANTE
}

enum EstadoSolicitud {
  PENDIENTE
  EN_PROCESO
  COMPLETADA
  RECHAZADA
}

enum Prioridad {
  ALTA
  MEDIA
  BAJA
}

enum EstadoReserva {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum EstadoUrgente {
  PENDIENTE
  EN_PROCESO
  RESUELTO
}

enum TipoPQRS {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  FELICITACION
}

enum EstadoPQRS {
  PENDIENTE
  EN_REVISION
  RESUELTA
  CERRADA
}

model User {
  id                    Int              @id @default(autoincrement())
  nombre                String
  email                 String           @unique
  password              String
  rol                   Rol
  cargo                 String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  solicitudesCreadas    Solicitud[]      @relation("SolicitanteRelation")
  solicitudesAsignadas  Solicitud[]      @relation("AsignadoRelation")
  reservasRadio         ReservaRadio[]
  reservasValleIA       ReservaValleIA[]
  urgentes              Urgente[]
  pqrs                  PQRS[]
  refreshTokens         RefreshToken[]
  notificaciones        Notificacion[]
}

model TipoSolicitud {
  id             String      @id
  nombre         String
  descripcion    String
  icono          String
  color          String
  tiempoEntrega  String
  tiempoDetalle  String
  solicitudes    Solicitud[]
}

model Solicitud {
  id             String           @id
  tipoId         String
  titulo         String
  descripcion    String           @default("")
  solicitanteId  Int
  estado         EstadoSolicitud
  asignadoAId    Int?
  prioridad      Prioridad
  tiempoEntrega  String           @default("")
  datos          Json
  archivoUrl     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tipo           TipoSolicitud    @relation(fields: [tipoId], references: [id])
  solicitante    User             @relation("SolicitanteRelation", fields: [solicitanteId], references: [id])
  asignadoA      User?            @relation("AsignadoRelation", fields: [asignadoAId], references: [id])
}

model ReservaRadio {
  id             Int           @id @default(autoincrement())
  dia            String
  hora           String
  semana         String
  estado         EstadoReserva
  solicitanteId  Int
  formulario     Json
  comentario     String?
  gestionadoPor  String?
  createdAt      DateTime      @default(now())
  solicitante    User          @relation(fields: [solicitanteId], references: [id])
}

model ReservaValleIA {
  id             Int                @id @default(autoincrement())
  dia            String
  hora           String
  semana         String
  estado         EstadoReserva
  solicitanteId  Int
  formulario     Json
  qrToken        String?            @unique
  createdAt      DateTime           @default(now())
  solicitante    User               @relation(fields: [solicitanteId], references: [id])
  asistencias    AsistenciaValle[]
}

model AsistenciaValle {
  id                    Int            @id @default(autoincrement())
  reservaId             Int
  nombreCompleto        String
  cedula                String
  telefono              String
  programa              String
  semestre              String
  nombreProfesor        String
  confirmado            Boolean        @default(false)
  calificacionClase     Int?
  calificacionHerramientas Int?
  queMejorar            String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  reserva               ReservaValleIA @relation(fields: [reservaId], references: [id])
}

model Urgente {
  id             Int            @id @default(autoincrement())
  titulo         String
  descripcion    String
  solicitanteId  Int
  estado         EstadoUrgente
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  solicitante    User           @relation(fields: [solicitanteId], references: [id])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model ProgramaFijo {
  id        Int    @id @default(autoincrement())
  programa  String
  dia       String
  hora      String
}

model PQRS {
  id             Int         @id @default(autoincrement())
  tipo           TipoPQRS
  titulo         String
  mensaje        String
  estado         EstadoPQRS  @default(PENDIENTE)
  respuesta      String?
  solicitanteId  Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  solicitante    User        @relation(fields: [solicitanteId], references: [id])
}

model Notificacion {
  id          Int      @id @default(autoincrement())
  userId      Int
  tipo        String
  titulo      String
  mensaje     String
  leida       Boolean  @default(false)
  referenceId String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

